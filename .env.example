# ── K2 Wealth v2 — Environment Variables ─────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env.

# Google Gemini (free tier) — get at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Supabase (free tier) — https://supabase.com → project → Settings → API
# Leave blank to use localStorage-only mode
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
